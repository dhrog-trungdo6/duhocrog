# ── Supabase (bắt buộc cho lead capture) ─────────────────────────────
# Lấy tại: Supabase Dashboard → Project Settings → API
# Giá trị THẬT đặt trong .env.local (gitignored) — KHÔNG dán key thật vào file này
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, KHÔNG expose ra client

# ── Tùy chọn (giai đoạn sau) ─────────────────────────────────────────
# RESEND_API_KEY=                  # email thông báo lead mới
# ADMIN_NOTIFY_EMAIL=
